{
  "name": "robbins-app",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20 <27"
  },
  "scripts": {
    "dev": "next dev --hostname 127.0.0.1 --port 3000",
    "dev:lan": "next dev --hostname 0.0.0.0 --port 3000",
    "dev:3002": "next dev --hostname 127.0.0.1 --port 3002",
    "dev:logs": "node scripts/dev-with-logs.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit",
    "test:formulation-migration": "node --experimental-strip-types --test src/lib/db/migrations/formulation-sessions-exploration.test.ts",
    "test:schema-drift": "node --experimental-strip-types --test src/lib/db/schema-drift-repair.test.ts",
    "test:user-account-delete": "node --experimental-strip-types --test src/lib/user-account-delete.test.ts",
    "test:frontend-audit": "node --experimental-strip-types --test src/lib/morning-ritual-storage.test.ts",
    "test:api-error": "node --experimental-strip-types --test src/lib/life-coach/api-error.test.ts",
    "test:generate-daily-steps-scope": "node --experimental-strip-types --test src/lib/life-coach/generate-daily-steps-scope.test.ts",
    "test:admin-session": "node --experimental-strip-types --test src/lib/db/admin-session.test.ts",
    "test:clerk-config": "node --experimental-strip-types --test src/lib/auth/clerk-config.test.ts",
    "test:domain-detail-url-state": "node --experimental-strip-types --test src/lib/life-coach/domain-detail-url-state.test.ts",
    "test:llm-structured-json": "node --experimental-strip-types --test src/lib/llm/request-structured-json.test.ts",
    "test:schemas-ai-request": "node --experimental-strip-types --test src/lib/life-coach/schemas-ai-request.test.ts",
    "test:week-window": "node --experimental-strip-types --test src/lib/goal-decomposition-tree/week-window.test.ts",
    "test:fallback-copy": "node --experimental-strip-types --test src/lib/life-coach/fallback-copy.test.ts",
    "test:as-enum": "node --experimental-strip-types --test src/lib/as-enum.test.ts",
    "test": "npm run test:frontend-audit && npm run test:api-error && npm run test:generate-daily-steps-scope && npm run test:formulation-migration && npm run test:schema-drift && npm run test:user-account-delete && npm run test:admin-session && npm run test:clerk-config && npm run test:domain-detail-url-state && npm run test:llm-structured-json && npm run test:schemas-ai-request && npm run test:week-window && npm run test:fallback-copy && npm run test:as-enum",
    "audit:objects": "node scripts/audit-object-relations.mjs",
    "knip": "knip",
    "knip:ci": "knip --dependencies",
    "audit:ci": "npm audit --audit-level=high",
    "audit:ci:prod": "npm audit --omit=dev --audit-level=high"
  },
  "dependencies": {
    "@clerk/nextjs": "^7.5.7",
    "@fontsource-variable/heebo": "^5.2.8",
    "@fontsource-variable/inter": "^5.2.8",
    "better-sqlite3": "^12.10.0",
    "next": "^16.2.6",
    "next-intl": "^4.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.25.0",
    "eslint-config-next": "^16.2.6",
    "knip": "^6.16.1",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.8.0"
  }
}
