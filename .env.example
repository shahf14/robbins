# ── AI ───────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=
OPENAI_LIFE_COACH_STRUCTURING_MODEL=gpt-4.1-mini
OPENAI_LIFE_COACH_DAILY_STEPS_MODEL=gpt-4.1-mini
OPENAI_LIFE_COACH_REVIEW_MODEL=gpt-4.1
# Default per-user AI API quota for routes without a route-specific override.
AI_RATE_LIMIT_MAX_REQUESTS=20
AI_RATE_LIMIT_WINDOW_SECONDS=3600

# ── Clerk (Authentication) ────────────────────────────────────────────────────
# Get from https://dashboard.clerk.com → your app → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Where Clerk redirects after sign-in / sign-up (legacy /sign-in redirects to /{locale}/sign-in)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# Clerk webhook secret (Webhooks → your endpoint → Signing Secret)
CLERK_WEBHOOK_SECRET=whsec_...

# ── Stripe (Payments) ─────────────────────────────────────────────────────────
# Get from https://dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Webhook secret (Stripe Dashboard → Webhooks → your endpoint → Signing secret)
STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs — create in Stripe Dashboard → Products
# Monthly: $19.99/month recurring
STRIPE_MONTHLY_PRICE_ID=price_...
# Annual: $149/year recurring
STRIPE_ANNUAL_PRICE_ID=price_...

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Generate: openssl rand -hex 32
LIFE_COACH_CRON_SECRET=

# Local/self-host fallback auth (required in production/Docker).
# Generate: openssl rand -hex 32
# Paste the same value in Settings → Local API authentication in the browser.
LOCAL_USER_ID=local-user
LOCAL_USER_EMAIL=
LOCAL_AUTH_TOKEN=c1096ccaa9e09ac9b150c65c0b94c5260eacf85a490eb4110f5975554c26c936
# Fail process start in production when LOCAL_AUTH_TOKEN/Clerk are missing (enabled in docker-compose).
STRICT_AUTH_BOOT=false
# Opt-in only: allow open API access on localhost in development (127.0.0.1).
# Use npm run dev:lan for LAN testing — always requires LOCAL_AUTH_TOKEN.
ALLOW_LOCAL_AUTH=true

# Admin access (email of the admin user)
ADMIN_EMAIL=
# Required for all /api/db/* routes. Send as x-admin-api-token.
ADMIN_API_TOKEN=

# Set true only when deployed behind a trusted reverse proxy.
TRUST_PROXY=false

# Trial duration in days (default: 7)
TRIAL_DAYS=7

# Keep secrets outside synced folders (e.g. not in OneDrive project root).
